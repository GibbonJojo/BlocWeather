# Database
DATABASE_URL=postgresql://blocweather:your_password@localhost/blocweather

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-secret-key-change-this-in-production

# Open-Meteo API
OPEN_METEO_API_URL=https://api.open-meteo.com/v1/forecast

# ETL Configuration
WEATHER_SYNC_INTERVAL_MINUTES=30

# Server
HOST=127.0.0.1
PORT=3000

# Logging
RUST_LOG=info,blocweather_backend=debug
